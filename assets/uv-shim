#!/usr/bin/env python3
"""ccbox uv shim — runs uv on the host via Unix socket.

Dependency management (sync, add, lock, pip, etc.) runs on the host so
hardlinks from the shared cache to .venv work natively.

Execution commands (uv run <cmd>) are split: sync on host, then exec
the command locally inside the container for proper sandboxing.
"""
import json
import os
import socket
import struct
import sys

SOCK_PATH = os.path.expanduser("~/.config/ccbox/run/uv.sock")

# ── protocol helpers ────────────────────────────────────────────────

def _connect():
    sock = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
    try:
        sock.connect(SOCK_PATH)
    except FileNotFoundError:
        print("ccbox: uv server socket not found", file=sys.stderr)
        sys.exit(1)
    except ConnectionRefusedError:
        print("ccbox: uv server not running", file=sys.stderr)
        sys.exit(1)
    return sock


def _send_request(sock, args):
    req = json.dumps({
        "args": args,
        "cwd": os.getcwd(),
        "env": {k: v for k, v in os.environ.items()
                if k.startswith("UV_") or k == "VIRTUAL_ENV"},
    })
    sock.sendall(req.encode() + b"\n")


def _recv_stream(sock):
    """Read framed response from server. Returns exit code."""
    exit_code = 1
    try:
        while True:
            header = b""
            while len(header) < 5:
                chunk = sock.recv(5 - len(header))
                if not chunk:
                    return exit_code
                header += chunk

            tag, length = struct.unpack("!BI", header)

            if tag == 0:  # exit code
                return length

            data = b""
            while len(data) < length:
                chunk = sock.recv(min(length - len(data), 65536))
                if not chunk:
                    break
                data += chunk

            if tag == 1:
                sys.stdout.buffer.write(data)
                sys.stdout.buffer.flush()
            elif tag == 2:
                sys.stderr.buffer.write(data)
                sys.stderr.buffer.flush()
    except (BrokenPipeError, ConnectionResetError):
        pass
    finally:
        sock.close()
    return exit_code


def proxy_to_host(args):
    """Send a uv command to the host and stream output. Returns exit code."""
    sock = _connect()
    _send_request(sock, args)
    return _recv_stream(sock)


# ── uv run argument parsing ─────────────────────────────────────────

# Flags that consume the next argument as a value
_RUN_FLAGS_WITH_VALUE = frozenset({
    "--with", "--with-requirements", "--python", "--package",
    "--extra", "--directory", "--project", "--env", "--env-file",
    "--cache-dir", "--python-preference", "--python-fetch",
    "--color", "--config-file",
})

# Flags relevant to sync (forwarded to `uv sync`)
_SYNC_FORWARDABLE = frozenset({
    "--frozen", "--locked", "--python", "--package",
    "--extra", "--all-extras", "--no-all-extras",
    "--dev", "--no-dev", "--directory", "--project",
    "--cache-dir", "--python-preference", "--python-fetch",
    "--no-cache", "--native-tls", "--no-native-tls",
    "--offline", "--no-offline", "--config-file", "--no-config",
})

# Flags with values among the sync-forwardable set
_SYNC_FLAGS_WITH_VALUE = _SYNC_FORWARDABLE & _RUN_FLAGS_WITH_VALUE


def _parse_run_args(args):
    """Parse args after 'run' into (uv_opts, cmd, flags).

    Returns (uv_options, command_args, has_with, module_mode, no_sync).
    """
    uv_opts = []
    has_with = False
    module_mode = False
    no_sync = False
    i = 0

    while i < len(args):
        arg = args[i]

        # Explicit separator
        if arg == "--":
            return uv_opts, args[i + 1:], has_with, module_mode, no_sync

        # --flag=value form
        if "=" in arg and arg.split("=", 1)[0] in _RUN_FLAGS_WITH_VALUE:
            key = arg.split("=", 1)[0]
            if key == "--with":
                has_with = True
            uv_opts.append(arg)
            i += 1
            continue

        # --flag value form
        if arg in _RUN_FLAGS_WITH_VALUE:
            if arg == "--with":
                has_with = True
            uv_opts.append(arg)
            if i + 1 < len(args):
                uv_opts.append(args[i + 1])
                i += 2
            else:
                i += 1
            continue

        # Boolean flags
        if arg in ("-m", "--module"):
            module_mode = True
            uv_opts.append(arg)
            i += 1
            continue

        if arg == "--no-sync":
            no_sync = True
            uv_opts.append(arg)
            i += 1
            continue

        if arg.startswith("-"):
            uv_opts.append(arg)
            i += 1
            continue

        # First positional = start of command
        return uv_opts, args[i:], has_with, module_mode, no_sync

    return uv_opts, [], has_with, module_mode, no_sync


def _build_sync_args(uv_opts):
    """Extract sync-relevant flags from uv run options."""
    sync_args = []
    i = 0
    while i < len(uv_opts):
        opt = uv_opts[i]
        bare = opt.split("=", 1)[0] if "=" in opt else opt

        if bare in _SYNC_FORWARDABLE:
            sync_args.append(opt)
            # If it's a flag-with-value in bare form, grab next too
            if "=" not in opt and bare in _SYNC_FLAGS_WITH_VALUE:
                if i + 1 < len(uv_opts):
                    sync_args.append(uv_opts[i + 1])
                    i += 2
                    continue
        i += 1
    return sync_args


def _find_venv():
    """Locate the project .venv, walking up from cwd."""
    d = os.getcwd()
    while True:
        candidate = os.path.join(d, ".venv")
        if os.path.isdir(candidate):
            return candidate
        parent = os.path.dirname(d)
        if parent == d:
            break
        d = parent
    # Fallback: VIRTUAL_ENV env var
    return os.environ.get("VIRTUAL_ENV")


def _exec_locally(cmd_args, module_mode):
    """Exec the command in the container with the venv activated."""
    venv = _find_venv()
    env = dict(os.environ)

    if venv:
        venv_bin = os.path.join(venv, "bin")
        env["VIRTUAL_ENV"] = venv
        env["PATH"] = venv_bin + ":" + env.get("PATH", "")
        # Remove PYTHONNOUSERSITE if set by uv
        env.pop("PYTHONNOUSERSITE", None)

    if module_mode:
        python = os.path.join(venv, "bin", "python") if venv else "python3"
        os.execvpe(python, [python, "-m"] + cmd_args, env)
    else:
        cmd = cmd_args[0]
        rest = cmd_args[1:]
        # Resolve from venv bin first
        if venv:
            venv_cmd = os.path.join(venv, "bin", cmd)
            if os.path.isfile(venv_cmd) and os.access(venv_cmd, os.X_OK):
                os.execvpe(venv_cmd, [cmd] + rest, env)
        # Fall back to PATH
        os.execvpe(cmd, cmd_args, env)


# ── main ─────────────────────────────────────────────────────────────

def main():
    args = sys.argv[1:]

    if not args:
        sys.exit(proxy_to_host(args))

    subcmd = args[0]

    # Subcommands that should always proxy entirely to host
    # (dependency management, no code execution)
    if subcmd in (
        "sync", "lock", "add", "remove", "pip", "venv", "export",
        "tree", "cache", "self", "version", "init", "build", "publish",
        "python",
    ):
        sys.exit(proxy_to_host(args))

    # `uv tool run` / `uv tool install` etc — proxy to host
    # (tool envs are isolated; install needs host, run is usually safe utils)
    if subcmd == "tool":
        sys.exit(proxy_to_host(args))

    # `uv run` — the interesting case
    if subcmd == "run":
        run_args = args[1:]
        uv_opts, cmd_args, has_with, module_mode, no_sync = _parse_run_args(run_args)

        # No command to run — just proxy (e.g. `uv run` with no args)
        if not cmd_args:
            sys.exit(proxy_to_host(args))

        # --with creates temporary overlay envs — too complex to split,
        # proxy entirely to host
        if has_with:
            sys.exit(proxy_to_host(args))

        # Sync deps on host (unless --no-sync)
        if not no_sync:
            sync_args = _build_sync_args(uv_opts)
            rc = proxy_to_host(["sync"] + sync_args)
            if rc != 0:
                sys.exit(rc)

        # Exec command locally in the container
        _exec_locally(cmd_args, module_mode)
        # _exec_locally calls execvpe, so we only reach here on error
        sys.exit(1)

    # Unknown subcommand — proxy to host as fallback
    sys.exit(proxy_to_host(args))


if __name__ == "__main__":
    main()
